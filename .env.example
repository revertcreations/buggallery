# =============================================================================
# BugGallery — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Docker / Nginx ---
PORT=8080

# --- WordPress ---
WP_URL=https://buggallery.revertcreations.com
WP_ENV=production

# --- Database ---
DB_NAME=buggallery
DB_USER=buggallery
DB_PASSWORD=
DB_ROOT_PASSWORD=

# --- Printful ---
# API token from https://www.printful.com/dashboard/developer
PRINTFUL_TOKEN=
# Set to true to send real orders to Printful (false = draft only)
PRINTFUL_CONFIRM=false

# --- Stripe ---
# Stripe keys are configured in WooCommerce > Settings > Payments > Stripe
# No env vars needed here — they're stored in the WordPress database.
# Test keys: pk_test_... / sk_test_...
# Live keys: pk_live_... / sk_live_...
